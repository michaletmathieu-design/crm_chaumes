generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          String         @default("COMMERCIAL")
  bands         UserBand[]
  accounts      Account[]
  sessions      Session[]
  tasks         Task[]
  opportunities Opportunity[]
  createdAt     DateTime       @default(now())
}

model Band {
  id           String         @id @default(cuid())
  name         String
  genre        String
  minFee       Int
  suggestedFee Int
  members      UserBand[]
  documents    Document[]
  opportunities Opportunity[]
  createdAt    DateTime       @default(now())
}

model UserBand {
  userId String
  bandId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  band   Band   @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@id([userId, bandId])
}

model Prospect {
  id          String        @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  city        String
  venueType   String
  capacity    Int?
  minFee      Int?
  maxFee      Int?
  opportunities Opportunity[] 
  documents     Document[]
  createdAt     DateTime      @default(now())
}

model Opportunity {
  id            String    @id @default(cuid())
  prospectId    String
  bandId        String
  assignedToId  String?
  stage         String    @default("NEW")
  prospect      Prospect    @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  band          Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)
  assignedTo    User?       @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  interactions  Interaction[]
  tasks         Task[]
  quotes        Quote[]
  events        Event[]
  @@unique([prospectId, bandId])
}

model Interaction {
  id            String      @id @default(cuid())
  opportunityId String
  type          String
  content       String
  date          DateTime    @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model Task {
  id            String       @id @default(cuid())
  title         String
  type          String       @default("FOLLOW_UP")
  priority      String       @default("MEDIUM")
  dueDate       DateTime
  isCompleted   Boolean      @default(false)
  opportunityId String?
  assignedToId  String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  assignedTo    User?        @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
}
model Event {
  id            String      @id @default(cuid())
  opportunityId String
  optionDate1   DateTime
  optionDate2   DateTime?
  confirmedDate DateTime?
  status        String      @default("OPTION_1")
  grossFee      Int         @default(0)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model Quote {
  id            String      @id @default(cuid())
  number        String      @unique
  amount        Int
  status        String      @default("DRAFT")
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model Document {
  id          String   @id @default(cuid())
  name        String
  category    String
  fileUrl     String
  prospectId  String?
  prospect    Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  bandId      String?
  band        Band?     @relation(fields: [bandId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}